# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_ID=price_xxxx          # $1,000/year plan
STRIPE_TRIAL_DAYS=5

# ── Hugging Face ─────────────────────────────────────────────
HUGGINGFACE_API_TOKEN=hf_xxxx
HF_DEFAULT_MODEL=tiiuae/falcon-7b-instruct
HF_FALLBACK_MODEL=allenai/OLMo-7B-Instruct-hf

# ── Resend (email) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=belon@yourdomain.com
RESEND_FROM_NAME=Belon AI

# ── HubSpot ──────────────────────────────────────────────────
HUBSPOT_APP_ID=your-app-id
HUBSPOT_CLIENT_ID=your-client-id
HUBSPOT_CLIENT_SECRET=your-client-secret
HUBSPOT_REDIRECT_URI=https://your-backend.railway.app/integrations/hubspot/callback

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,https://app.belon.ai

# ── Signal Engine ────────────────────────────────────────────
SIGNAL_ENGINE_INTERVAL_MINUTES=15
SIGNAL_ENGINE_BATCH_SIZE=50
